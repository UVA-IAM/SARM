# SARM Source System Bridge — Environment Variables
# Copy to .env and set values for your environment.
# All values here are placeholders.

# Path to YAML configuration file (default: config.yaml)
# SARM_CONFIG=/path/to/config.yaml

# SQLAlchemy database connection string.
# Overrides the database.url in the YAML config.
# Examples:
#   SQLite:   sqlite:////app/data/sample.sqlite
#   PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/sarm
#   MySQL:    mysql+pymysql://user:pass@localhost:3306/sarm
SARM_DATABASE_URL=sqlite:////app/data/sample.sqlite

# Bearer token for local testing.
# In production, authentication is agreed between the parties (§8).
# This is only used for local convenience — never commit real tokens.
# SARM_BEARER_TOKEN=your-test-token-here

# Decision response mode: "sync" (default, returns 201/200) or
# "async" (returns 202 Accepted, AE awaits completion event).
# SARM_DECISIONS_SYNC_MODE=sync

# Decision replay disposition: "allow" (default, accepts new decisions
# for any item) or "disallow" (returns 409 if a new decision targets an
# item that already has a recorded decision).
# SARM_DECISIONS_REPLAY_DISPOSITION=allow
