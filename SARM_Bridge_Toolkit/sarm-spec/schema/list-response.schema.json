{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SARM ListResponse",
  "description": "Paginated list response envelope per §4.3. Returned by GET /sarm/v1/ScopeItems.",
  "type": "object",
  "required": ["schemas", "totalResults"],
  "properties": {
    "schemas": {
      "type": "array",
      "items": {
        "type": "string",
        "const": "urn:ietf:params:sarm:api:messages:1.0:ListResponse"
      },
      "minItems": 1
    },
    "totalResults": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of ScopeItems matching the query."
    },
    "startIndex": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "1-based index of the first resource on this page."
    },
    "itemsPerPage": {
      "type": "integer",
      "minimum": 1,
      "default": 100,
      "maximum": 1000,
      "description": "Requested page size (max 1000 per §4.2)."
    },
    "Resources": {
      "type": "array",
      "items": {
        "$ref": "scope-item.schema.json"
      },
      "description": "Array of ScopeItem resources on this page."
    }
  },
  "additionalProperties": false
}
