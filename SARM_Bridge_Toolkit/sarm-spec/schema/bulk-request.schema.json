{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SARM BulkRequest",
  "description": "Batch decision notification per §5.2. Allows multiple Decisions to be sent in a single POST to /sarm/v1/Decisions.",
  "type": "object",
  "required": ["schemas", "Operations"],
  "properties": {
    "schemas": {
      "type": "array",
      "items": {
        "type": "string",
        "const": "urn:ietf:params:sarm:api:messages:1.0:BulkRequest"
      },
      "minItems": 1
    },
    "Operations": {
      "type": "array",
      "minItems": 1,
      "description": "Array of bulk operations. Each carries method, path, and data fields.",
      "items": {
        "type": "object",
        "required": ["method", "path", "data"],
        "properties": {
          "method": {
            "type": "string",
            "const": "POST",
            "description": "Bulk method. For Decision notifications, always POST."
          },
          "path": {
            "type": "string",
            "const": "/sarm/v1/Decisions",
            "description": "Target path for this operation."
          },
          "data": {
            "$ref": "decision.schema.json",
            "description": "The Decision resource to apply."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
